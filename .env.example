# Required
OPENROUTER_API_KEY=
OPENAI_API_KEY=
DATABASE_URL=

# Optional runtime settings
OPENROUTER_MODEL=openai/gpt-5.4
CODEX_MODEL=gpt-5.4-2026-03-05
OPENROUTER_SEARCH_ENGINE=auto
OPENROUTER_MAX_RESULTS=8
OPENROUTER_MAX_TOTAL_RESULTS=24
RESEARCH_PROVIDER=openrouter
WIND_FARM_SOURCE_TABLE=core_wind_farms
WIND_FARM_REPORTS_DIR=reports
PROMPT_TRACE_ENABLED=false
PROMPT_TRACE_DIR=prompt-traces

# Optional OpenRouter ranking headers
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=boundary-layer-ai-web-search

# Optional HTTP service settings for deployed moderation flows
HOST=0.0.0.0
PORT=3001
WEB_SEARCH_SERVICE_TOKEN=
