# Required
OPENROUTER_API_KEY=
DATABASE_URL=

# Optional runtime settings
OPENROUTER_MODEL=openai/gpt-4.1
OPENROUTER_SEARCH_ENGINE=firecrawl
OPENROUTER_SEARCH_MODE=plugin
OPENROUTER_MAX_RESULTS=6
OPENROUTER_MAX_TOTAL_RESULTS=18
WIND_FARM_SOURCE_TABLE=windfarm_database
WIND_FARM_REPORTS_DIR=reports
PROMPT_TRACE_ENABLED=false
PROMPT_TRACE_DIR=prompt-traces

# Optional OpenRouter ranking headers
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=boundary-layer-ai-web-search
